# SUNLIGHT Environment Configuration
# Copy to .env and update values before running docker-compose up

# PostgreSQL
POSTGRES_DB=sunlight
POSTGRES_USER=sunlight
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# API
SUNLIGHT_PORT=8000
SUNLIGHT_AUTH_ENABLED=true
SUNLIGHT_LOG_LEVEL=INFO
SUNLIGHT_DB_PATH=/app/data/sunlight.db

# Webhook worker
WEBHOOK_WORKER_CONCURRENCY=4
WEBHOOK_RETRY_MAX=3

# Observability
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=changeme

# Cloud deploy (optional)
AWS_REGION=us-east-1
AWS_PROFILE=sunlight
